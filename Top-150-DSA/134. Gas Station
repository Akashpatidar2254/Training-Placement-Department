//TLE O(n*n)
class Solution {
public:
    int canCompleteCircuit(vector<int>& gas, vector<int>& cost) {
        int n=gas.size();
        vector<int> diff(n);
        int total_gas=INT_MIN;
        int total_cost=INT_MIN;
        for(int i=0;i<n;i++){
            total_cost+=cost[i];
            total_gas+=gas[i];
            diff[i]=gas[i]-cost[i];
        }
        if(total_cost>total_gas){
            return -1;
        }
        else{
            for(int i=0;i<n;i++){
                if(diff[i]>=0){
                    int fuel=diff[(i)%n];
                    int start=(i+1)%n;
                    while(fuel>=0){
                        if(start%n==i){
                            return i;
                        }
                        fuel+=diff[start%n];
                        start++;

                    }
                }

            }
        }

