//DP(recursion+memoi)
class Solution {
public:
int t[100001][2];
int solve(vector<int>& prices,int i, int buy){
    if(i>=prices.size()){
        return 0;
    }
    if(t[i][buy]!=-1){
        return t[i][buy];
    }
    int profit=0;
    if(buy){
        int take=solve(prices,i+1,0)-prices[i];
        int not_take=solve(prices,i+1,1);
        profit=max(profit,max(take,not_take));
    }
    else{
        int take=solve(prices,i+1,1)+prices[i];
        int not_take=solve(prices,i+1,0);
        profit=max(profit,max(take,not_take));
    }

    
    

return t[i][buy]=profit;

}


    int maxProfit(vector<int>& prices) {
        memset(t,-1,sizeof(t));
        int profit=solve(prices,0,1);
        if(profit<0){
            return 0;
        }
        else{
            return profit;
        }
        


        
    }
};
