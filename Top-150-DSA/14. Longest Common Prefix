class Solution {
public:
    string longestCommonPrefix(vector<string>& strs) {
        int n=strs.size();
        
        vector<string> result(n);
        result[0]=strs[0];

        for(int i=1;i<n;i++){
            string s1=result[i-1];
            string s2=strs[i];
            string level="";
            int ptr=0;
            while(ptr<s1.size() && ptr<s2.size()  && s1[ptr]==s2[ptr]){
                    level.push_back(s1[ptr]);
                    ptr++;
               }
               result[i]=level;
               
            }
            return result[n-1];

        }

        
    
};
