//DP(recur+memo)
class Solution {
public:
    int t[10001];
    bool solve(vector<int>& nums, int idx) {
        if (idx == nums.size() - 1) return true;
        if (idx >= nums.size()) return false;
         if(t[idx]!=-1) return t[idx];
        for (int jump = 1; jump <= nums[idx]; jump++) {
            if (solve(nums, idx + jump)) {
                return t[idx] = true;
            }
        }
        return t[idx]=false;
    }

    bool canJump(vector<int>& nums) {
        memset(t,-1,sizeof(t));
        return solve(nums, 0);
    }
};
